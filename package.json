{
  "name": "ttf-renderer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "biome lint ./src ./test",
    "format": "biome format --write ./src ./test",
    "check": "biome check --write ./src ./test",
    "debug:parse": "bun --inspect-brk scripts/debug-parse.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "lil-gui": "^0.21.0"
  }
}
